# Target DVR network address
CAM_IP="192.168.1.100"

# DVR credentials
CAM_USER="admin"
CAM_PASS="your_password_here"

# 1 for Main Stream, 2 for Sub Stream
CAM_STREAM="1"

# Grid snapshot update frequency in seconds
POLL_INTERVAL="0.5"

# Available cameras on the DVR (comma-separated list)
TARGET_CAMERAS="1,2,3,4,6,7,8,9,10"

# Thread grouping for snapshot fetching
GROUP_1="1,2,3,4"
GROUP_2="6,7,8,9,10"